diff --git a/net/Kconfig b/net/Kconfig
index 62266eaf0e95..1be83f78b6e2 100644
--- a/net/Kconfig
+++ b/net/Kconfig
@@ -320,6 +320,22 @@ config RFS_ACCEL
 	  Allowing drivers for multiqueue hardware with flow filter tables to
 	  accelerate RFS.
 
+config BPF_RFS
+	bool "BPF-based Receive Flow Steering"
+	depends on BPF_SYSCALL
+	depends on NET
+	select BPF_MPROG
+	help
+	  This option enables BPF-based Receive Flow Steering (BPF-RFS),
+	  which allows using BPF programs to steer receive packets to
+	  specific CPUs. This is an alternative to the traditional RPS/RFS
+	  implementation and can work independently without CONFIG_RPS.
+
+	  BPF-RFS uses BPF MAPs for flow tables and allows custom CPU
+	  selection algorithms through BPF programs.
+
+	  If unsure, say N.
+
 config SOCK_RX_QUEUE_MAPPING
 	bool
 
diff --git a/net/core/dev.c b/net/core/dev.c
index 37078b5b6628..93e271c7c755 100644
--- a/net/core/dev.c
+++ b/net/core/dev.c
@@ -162,6 +162,7 @@
 #include <net/page_pool/helpers.h>
 #include <net/page_pool/memory_provider.h>
 #include <net/rps.h>
+#include <net/rfs_bpf.h>
 #include <linux/phy_link_topology.h>
 
 #include "dev.h"
@@ -5670,6 +5671,29 @@ static int netif_rx_internal(struct sk_buff *skb)
 
 	trace_netif_rx(skb);
 
+#ifdef CONFIG_BPF_RFS
+	/* BPF-RFS takes priority over traditional RPS/RFS */
+	if (bpf_rfs_is_needed()) {
+		struct bpf_mprog_entry *rfs_entry;
+
+		rcu_read_lock();
+
+		rfs_entry = rcu_dereference(skb->dev->bpf_rfs);
+		if (rfs_entry) {
+			int cpu = bpf_rfs_run(rfs_entry, skb);
+			u32 qtail;
+
+			if (cpu < 0)
+				cpu = smp_processor_id();
+
+			ret = enqueue_to_backlog(skb, cpu, &qtail);
+			rcu_read_unlock();
+			return ret;
+		}
+		rcu_read_unlock();
+	}
+#endif
+
 #ifdef CONFIG_RPS
 	if (static_branch_unlikely(&rps_needed)) {
 		struct rps_dev_flow voidflow, *rflow = &voidflow;
@@ -6366,6 +6390,26 @@ static int netif_receive_skb_internal(struct sk_buff *skb)
 		return NET_RX_SUCCESS;
 
 	rcu_read_lock();
+
+#ifdef CONFIG_BPF_RFS
+	/* BPF-RFS takes priority over traditional RPS/RFS */
+	if (bpf_rfs_is_needed()) {
+		struct bpf_mprog_entry *rfs_entry;
+
+		rfs_entry = rcu_dereference(skb->dev->bpf_rfs);
+		if (rfs_entry) {
+			int cpu = bpf_rfs_run(rfs_entry, skb);
+			if (cpu >= 0) {
+				u32 qtail;
+				ret = enqueue_to_backlog(skb, cpu, &qtail);
+				rcu_read_unlock();
+				return ret;
+			}
+			/* BPF didn't select CPU, fall through to RPS/RFS */
+		}
+	}
+#endif
+
 #ifdef CONFIG_RPS
 	if (static_branch_unlikely(&rps_needed)) {
 		struct rps_dev_flow voidflow, *rflow = &voidflow;
diff --git a/net/core/filter.c b/net/core/filter.c
index 2f023999f046..b8408b0b2895 100644
--- a/net/core/filter.c
+++ b/net/core/filter.c
@@ -11209,6 +11209,148 @@ static u32 sk_msg_convert_ctx_access(enum bpf_access_type type,
 	return insn - insn_buf;
 }
 
+#ifdef CONFIG_BPF_RFS
+#include <net/rfs_bpf.h>
+
+/* BPF helper: Record flow to CPU mapping in sock flow table */
+BPF_CALL_3(bpf_rfs_record_flow, struct bpf_map *, map, u32, hash, u32, cpu)
+{
+	struct bpf_rfs_sock_flow_key key = { .hash = hash };
+	struct bpf_rfs_sock_flow_val val = {
+		.cpu = cpu,
+		.timestamp = bpf_ktime_get_ns(),
+		.pid = current->pid
+	};
+
+	if (cpu >= nr_cpu_ids)
+		return -EINVAL;
+
+	return map->ops->map_update_elem(map, &key, &val, BPF_ANY);
+}
+
+static const struct bpf_func_proto bpf_rfs_record_flow_proto = {
+	.func		= bpf_rfs_record_flow,
+	.gpl_only	= false,
+	.ret_type	= RET_INTEGER,
+	.arg1_type	= ARG_CONST_MAP_PTR,
+	.arg2_type	= ARG_ANYTHING,
+	.arg3_type	= ARG_ANYTHING,
+};
+
+/* BPF helper: Lookup flow in sock flow table */
+BPF_CALL_3(bpf_rfs_lookup_flow, struct bpf_map *, map, u32, hash, u32 *, cpu)
+{
+	struct bpf_rfs_sock_flow_key key = { .hash = hash };
+	struct bpf_rfs_sock_flow_val *val;
+
+	val = map->ops->map_lookup_elem(map, &key);
+	if (!val)
+		return -ENOENT;
+
+	*cpu = val->cpu;
+	return 0;
+}
+
+static const struct bpf_func_proto bpf_rfs_lookup_flow_proto = {
+	.func		= bpf_rfs_lookup_flow,
+	.gpl_only	= false,
+	.ret_type	= RET_INTEGER,
+	.arg1_type	= ARG_CONST_MAP_PTR,
+	.arg2_type	= ARG_ANYTHING,
+	.arg3_type	= ARG_PTR_TO_INT,
+};
+
+static const struct bpf_func_proto *
+rfs_func_proto(enum bpf_func_id func_id, const struct bpf_prog *prog)
+{
+	switch (func_id) {
+	case BPF_FUNC_map_lookup_elem:
+		return &bpf_map_lookup_elem_proto;
+	case BPF_FUNC_map_update_elem:
+		return &bpf_map_update_elem_proto;
+	case BPF_FUNC_map_delete_elem:
+		return &bpf_map_delete_elem_proto;
+	case BPF_FUNC_map_push_elem:
+		return &bpf_map_push_elem_proto;
+	case BPF_FUNC_map_pop_elem:
+		return &bpf_map_pop_elem_proto;
+	case BPF_FUNC_map_peek_elem:
+		return &bpf_map_peek_elem_proto;
+	case BPF_FUNC_ktime_get_ns:
+		return &bpf_ktime_get_ns_proto;
+	case BPF_FUNC_ktime_get_boot_ns:
+		return &bpf_ktime_get_boot_ns_proto;
+	case BPF_FUNC_ktime_get_coarse_ns:
+		return &bpf_ktime_get_coarse_ns_proto;
+	case BPF_FUNC_rfs_record_flow:
+		return &bpf_rfs_record_flow_proto;
+	case BPF_FUNC_rfs_lookup_flow:
+		return &bpf_rfs_lookup_flow_proto;
+	default:
+		return bpf_base_func_proto(func_id, prog);
+	}
+}
+
+static bool rfs_is_valid_access(int off, int size, enum bpf_access_type type,
+				const struct bpf_prog *prog,
+				struct bpf_insn_access_aux *info)
+{
+	if (type == BPF_WRITE)
+		return false;
+
+	if (off < 0 || off >= sizeof(struct bpf_rfs_ctx))
+		return false;
+
+	if (off % size != 0)
+		return false;
+
+	return true;
+}
+
+static int rfs_convert_ctx_access(enum bpf_access_type type,
+				  const struct bpf_insn *si,
+				  struct bpf_insn *insn_buf,
+				  struct bpf_prog *prog,
+				  u32 *target_size)
+{
+	struct bpf_insn *insn = insn_buf;
+
+	switch (si->off) {
+	case offsetof(struct bpf_rfs_ctx, hash):
+		*insn++ = BPF_LDX_MEM(BPF_W, si->dst_reg, si->src_reg,
+				      offsetof(struct bpf_rfs_ctx, hash));
+		break;
+	case offsetof(struct bpf_rfs_ctx, current_cpu):
+		*insn++ = BPF_LDX_MEM(BPF_W, si->dst_reg, si->src_reg,
+				      offsetof(struct bpf_rfs_ctx, current_cpu));
+		break;
+	case offsetof(struct bpf_rfs_ctx, queue_mapping):
+		*insn++ = BPF_LDX_MEM(BPF_W, si->dst_reg, si->src_reg,
+				      offsetof(struct bpf_rfs_ctx, queue_mapping));
+		break;
+	case offsetof(struct bpf_rfs_ctx, ifindex):
+		*insn++ = BPF_LDX_MEM(BPF_W, si->dst_reg, si->src_reg,
+				      offsetof(struct bpf_rfs_ctx, ifindex));
+		break;
+	case offsetof(struct bpf_rfs_ctx, napi_id):
+		*insn++ = BPF_LDX_MEM(BPF_W, si->dst_reg, si->src_reg,
+				      offsetof(struct bpf_rfs_ctx, napi_id));
+		break;
+	}
+
+	return insn - insn_buf;
+}
+
+const struct bpf_verifier_ops rfs_verifier_ops = {
+	.get_func_proto		= rfs_func_proto,
+	.is_valid_access	= rfs_is_valid_access,
+	.convert_ctx_access	= rfs_convert_ctx_access,
+};
