diff --git a/kernel/bpf/rfs.c b/kernel/bpf/rfs.c
new file mode 100644
index 000000000000..6c20dafb0d29
--- /dev/null
+++ b/kernel/bpf/rfs.c
@@ -0,0 +1,355 @@
+// SPDX-License-Identifier: GPL-2.0-or-later
+/*
+ * BPF-based Receive Flow Steering (BPF-RFS)
+ *
+ * This module implements a BPF-driven alternative to traditional RFS,
+ * allowing custom CPU selection algorithms through BPF programs.
+ */
+
+#include <linux/bpf.h>
+#include <linux/bpf_mprog.h>
+#include <linux/filter.h>
+#include <linux/netdevice.h>
+#include <linux/slab.h>
+#include <linux/static_key.h>
+#include <net/rfs_bpf.h>
+
+DEFINE_STATIC_KEY_FALSE(bpf_rfs_needed);
+EXPORT_SYMBOL_GPL(bpf_rfs_needed);
+
+/* bpf_rfs_entry operations */
+static struct bpf_rfs_entry *bpf_rfs_entry_alloc(void)
+{
+	struct bpf_rfs_entry *entry;
+
+	entry = kzalloc(sizeof(*entry), GFP_KERNEL);
+	if (!entry)
+		return NULL;
+
+	bpf_mprog_bundle_init(&entry->bundle);
+	return entry;
+}
+
+static void bpf_rfs_entry_free(struct rcu_head *rcu)
+{
+	struct bpf_rfs_entry *entry = container_of(rcu, struct bpf_rfs_entry, rcu);
+
+	bpf_mprog_bundle_destroy(&entry->bundle);
+	kfree(entry);
+}
+
+/* Get or create entry for device */
+static struct bpf_mprog_entry *bpf_rfs_entry_fetch_or_create(
+	struct net_device *dev, bool *created)
+{
+	struct bpf_rfs_entry *entry;
+
+	entry = rcu_dereference_rtnl(dev->bpf_rfs);
+	if (entry)
+		return &entry->bundle.a;
+
+	*created = true;
+	entry = bpf_rfs_entry_alloc();
+	if (!entry)
+		return ERR_PTR(-ENOMEM);
+
+	rcu_assign_pointer(dev->bpf_rfs, entry);
+	return &entry->bundle.a;
+}
+
+static inline void bpf_rfs_entry_update(struct net_device *dev,
+					struct bpf_mprog_entry *entry)
+{
+	struct bpf_rfs_entry *rfs_entry;
+
+	ASSERT_RTNL();
+	rfs_entry = container_of(entry->parent, struct bpf_rfs_entry, bundle);
+	rcu_assign_pointer(dev->bpf_rfs, rfs_entry);
+}
+
+/* Run BPF-RFS programs */
+int bpf_rfs_run(const struct bpf_mprog_entry *entry, struct sk_buff *skb)
+{
+	struct bpf_rfs_ctx_kern ctx_kern = {};
+	struct bpf_rfs_ctx ctx;
+	const struct bpf_mprog_fp *fp;
+	const struct bpf_prog *prog;
+	int ret = -1;
+
+	/* Initialize context */
+	ctx_kern.skb = skb;
+	ctx_kern.hash = skb_get_hash(skb);
+	ctx_kern.current_cpu = smp_processor_id();
+	ctx_kern.dev = skb->dev;
+	ctx_kern.selected_cpu = -1;
+	ctx_kern.cpu_selected = false;
+
+	/* Fill user-visible context */
+	ctx.hash = ctx_kern.hash;
+	ctx.current_cpu = ctx_kern.current_cpu;
+	ctx.queue_mapping = skb_get_queue_mapping(skb);
+	ctx.ifindex = skb->dev->ifindex;
+	ctx.napi_id = skb->napi_id;
+	ctx.reserved = 0;
+
+	/* Execute BPF programs */
+	bpf_mprog_foreach_prog(entry, fp, prog) {
+		bpf_compute_data_pointers(skb);
+		ret = bpf_prog_run(prog, &ctx);
+
+		if (ret >= 0 && ret < nr_cpu_ids) {
+			/* Valid CPU selected */
+			ctx_kern.selected_cpu = ret;
+			ctx_kern.cpu_selected = true;
+			break;
+		}
+		/* Continue to next program if not selected */
+	}
+
+	return ctx_kern.cpu_selected ? ctx_kern.selected_cpu : -1;
+}
+EXPORT_SYMBOL_GPL(bpf_rfs_run);
+
+/* Attach BPF program */
+int bpf_rfs_prog_attach(const union bpf_attr *attr, struct bpf_prog *prog)
+{
+	struct net *net = current->nsproxy->net_ns;
+	struct bpf_mprog_entry *entry, *entry_new;
+	struct net_device *dev;
+	bool created = false;
+	int ret;
+
+	rtnl_lock();
+	dev = __dev_get_by_index(net, attr->target_ifindex);
+	if (!dev) {
+		ret = -ENODEV;
+		goto unlock;
+	}
+
+	entry = bpf_rfs_entry_fetch_or_create(dev, &created);
+	if (IS_ERR(entry)) {
+		ret = PTR_ERR(entry);
+		goto unlock;
+	}
+
+	ret = bpf_mprog_attach(entry, &entry_new, prog, NULL,
+			       attr->attach_flags, attr->relative_fd,
+			       attr->expected_revision);
+	if (!ret) {
+		if (entry != entry_new) {
+			bpf_rfs_entry_update(dev, entry_new);
+			static_branch_inc(&bpf_rfs_needed);
+		}
+		bpf_mprog_commit(entry);
+	}
+
+unlock:
+	rtnl_unlock();
+	return ret;
+}
+
+/* Detach BPF program */
+int bpf_rfs_prog_detach(const union bpf_attr *attr, struct bpf_prog *prog)
+{
+	struct net *net = current->nsproxy->net_ns;
+	struct bpf_mprog_entry *entry, *entry_new;
+	struct net_device *dev;
+	int ret;
+
+	rtnl_lock();
+	dev = __dev_get_by_index(net, attr->target_ifindex);
+	if (!dev) {
+		ret = -ENODEV;
+		goto unlock;
+	}
+
+	entry = rcu_dereference_rtnl(dev->bpf_rfs);
+	if (!entry) {
+		ret = -ENOENT;
+		goto unlock;
+	}
+
+	ret = bpf_mprog_detach(entry, &entry_new, prog, NULL,
+			       attr->attach_flags, attr->relative_fd,
+			       attr->expected_revision);
+	if (!ret) {
+		if (entry != entry_new) {
+			bpf_rfs_entry_update(dev, entry_new);
+			static_branch_dec(&bpf_rfs_needed);
+		}
+		bpf_mprog_commit(entry);
+	}
+
+unlock:
+	rtnl_unlock();
+	return ret;
+}
+
+/* Query attached programs */
+int bpf_rfs_prog_query(const union bpf_attr *attr, union bpf_attr __user *uattr)
+{
+	struct net *net = current->nsproxy->net_ns;
+	struct bpf_mprog_entry *entry;
+	struct net_device *dev;
+	int ret;
+
+	rtnl_lock();
+	dev = __dev_get_by_index(net, attr->query.target_ifindex);
+	if (!dev) {
+		ret = -ENODEV;
+		goto unlock;
+	}
+
+	entry = rcu_dereference_rtnl(dev->bpf_rfs);
+	if (!entry) {
+		ret = -ENOENT;
+		goto unlock;
+	}
+
+	ret = bpf_mprog_query(entry, attr, uattr);
+
+unlock:
+	rtnl_unlock();
+	return ret;
+}
+
+/* Link release callback */
+static void bpf_rfs_link_dealloc(struct bpf_link *link)
+{
+	struct bpf_rfs_link *rfs_link = container_of(link, struct bpf_rfs_link, link);
+
+	kfree(rfs_link);
+}
+
+/* Link detach callback */
+static int bpf_rfs_link_detach(struct bpf_link *link)
+{
+	struct bpf_rfs_link *rfs_link = container_of(link, struct bpf_rfs_link, link);
+	struct bpf_mprog_entry *entry, *entry_new;
+	int ret;
+
+	rtnl_lock();
+
+	entry = rcu_dereference_rtnl(rfs_link->dev->bpf_rfs);
+	if (!entry) {
+		ret = -ENOENT;
+		goto unlock;
+	}
+
+	ret = bpf_mprog_detach(entry, &entry_new, NULL, link, 0, 0, 0);
+	if (!ret) {
+		if (entry != entry_new) {
+			bpf_rfs_entry_update(rfs_link->dev, entry_new);
+			static_branch_dec(&bpf_rfs_needed);
+		}
+		bpf_mprog_commit(entry);
+	}
+
+unlock:
+	rtnl_unlock();
+	return ret;
+}
+
+static const struct bpf_link_ops bpf_rfs_link_lops = {
+	.release = bpf_rfs_link_release,
+	.dealloc = bpf_rfs_link_dealloc,
+	.detach = bpf_rfs_link_detach,
+};
+
+/* Link attach */
+int bpf_rfs_link_attach(const union bpf_attr *attr, struct bpf_prog *prog)
+{
+	struct net *net = current->nsproxy->net_ns;
+	struct bpf_mprog_entry *entry, *entry_new;
+	struct bpf_link_primer link_primer;
+	struct bpf_rfs_link *rfs_link;
+	struct net_device *dev;
+	bool created = false;
+	int ret;
+
+	rfs_link = kzalloc(sizeof(*rfs_link), GFP_USER);
+	if (!rfs_link)
+		return -ENOMEM;
+
+	bpf_link_init(&rfs_link->link, BPF_LINK_TYPE_UNSPEC, &bpf_rfs_link_lops, prog);
+
+	rtnl_lock();
+
+	dev = __dev_get_by_index(net, attr->link_create.target_ifindex);
+	if (!dev) {
+		ret = -ENODEV;
+		goto unlock_free;
+	}
+
+	ret = bpf_link_prime(&rfs_link->link, &link_primer);
+	if (ret)
+		goto unlock_free;
+
+	entry = bpf_rfs_entry_fetch_or_create(dev, &created);
+	if (IS_ERR(entry)) {
+		ret = PTR_ERR(entry);
+		goto unlock_cancel;
+	}
+
+	ret = bpf_mprog_attach(entry, &entry_new, prog, &rfs_link->link,
+			       attr->link_create.flags,
+			       attr->link_create.relative_fd,
+			       attr->link_create.expected_revision);
+	if (!ret) {
+		if (entry != entry_new) {
+			bpf_rfs_entry_update(dev, entry_new);
+			static_branch_inc(&bpf_rfs_needed);
+		}
+		bpf_mprog_commit(entry);
+		rfs_link->dev = dev;
+		dev_hold(dev);
+	}
+
+unlock_cancel:
+	if (ret)
+		bpf_link_cancel(&link_primer);
+	else
+		ret = bpf_link_settle(&link_primer);
+
+unlock_free:
+	rtnl_unlock();
+	if (ret)
+		kfree(rfs_link);
+	return ret;
+}
+
+/* Link release - called when link is being destroyed */
+void bpf_rfs_link_release(struct bpf_link *link)
+{
+	struct bpf_rfs_link *rfs_link = container_of(link, struct bpf_rfs_link, link);
+
+	rtnl_lock();
+	if (rfs_link->dev)
+		dev_put(rfs_link->dev);
+	rtnl_unlock();
+}
+
+/* Uninstall from device - called when device is being unregistered */
+void dev_bpf_rfs_uninstall(struct net_device *dev)
+{
+	struct bpf_rfs_entry *entry;
+
+	ASSERT_RTNL();
+
+	entry = rcu_dereference_protected(dev->bpf_rfs, 1);
+	if (!entry)
+		return;
+
+	RCU_INIT_POINTER(dev->bpf_rfs, NULL);
+	call_rcu(&entry->rcu, bpf_rfs_entry_free);
+	static_branch_dec(&bpf_rfs_needed);
+}
+
+static int __init bpf_rfs_init(void)
+{
+	/* Register mprog support for BPF_PROG_TYPE_RFS */
+	bpf_mprog_support(BPF_PROG_TYPE_RFS);
+	return 0;
+}
+
+late_initcall(bpf_rfs_init);
