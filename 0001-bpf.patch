diff --git a/samples/bpf/bpf_rfs_kern.c b/samples/bpf/bpf_rfs_kern.c
new file mode 100644
index 000000000000..1451ccbff2d9
--- /dev/null
+++ b/samples/bpf/bpf_rfs_kern.c
@@ -0,0 +1,96 @@
+// SPDX-License-Identifier: GPL-2.0-or-later
+/*
+ * Sample BPF-RFS program
+ *
+ * This program demonstrates how to use BPF-RFS to steer network packets
+ * to specific CPUs based on flow information.
+ */
+
+#include <linux/bpf.h>
+#include <linux/rfs_bpf.h>
+#include <bpf/bpf_helpers.h>
+#include <bpf/bpf_tracing.h>
+
+/* Sock flow table - records which CPU is processing each flow */
+struct {
+	__uint(type, BPF_MAP_TYPE_HASH);
+	__uint(max_entries, 32768);
+	__type(key, struct bpf_rfs_sock_flow_key);
+	__type(value, struct bpf_rfs_sock_flow_val);
+} sock_flow_table SEC(".maps");
+
+/* Dev flow table - per-queue flow state for migration tracking */
+struct {
+	__uint(type, BPF_MAP_TYPE_PERCPU_ARRAY);
+	__uint(max_entries, 4096);
+	__type(key, struct bpf_rfs_dev_flow_key);
+	__type(value, struct bpf_rfs_dev_flow_val);
+} dev_flow_table SEC(".maps");
+
+/* CPU online mask - for checking CPU availability */
+struct {
+	__uint(type, BPF_MAP_TYPE_ARRAY);
+	__uint(max_entries, 256);
+	__type(key, __u32);
+	__type(value, __u32);
+} cpu_online_map SEC(".maps");
+
+/*
+ * RFS program entry point
+ * Returns: target CPU id (0 to nr_cpu_ids-1) or -1 to let kernel decide
+ */
+SEC("rfs")
+int rfs_select_cpu(struct bpf_rfs_ctx *ctx)
+{
+	struct bpf_rfs_sock_flow_key sock_key = { .hash = ctx->hash };
+	struct bpf_rfs_sock_flow_val *sock_val;
+	struct bpf_rfs_dev_flow_key dev_key;
+	struct bpf_rfs_dev_flow_val *dev_val;
+	__u32 target_cpu;
+	__u32 slot;
+	__u32 *online;
+
+	/* 1. Lookup sock flow table for target CPU */
+	sock_val = bpf_map_lookup_elem(&sock_flow_table, &sock_key);
+	if (!sock_val)
+		return -1;  /* No flow recorded, let kernel decide */
+
+	target_cpu = sock_val->cpu;
+
+	/* 2. Check if target CPU is valid and online */
+	online = bpf_map_lookup_elem(&cpu_online_map, &target_cpu);
+	if (!online || !*online)
+		return -1;  /* Target CPU not available */
+
+	/* 3. Lookup/update dev flow table for migration check */
+	slot = ctx->hash & 0xFFF;  /* 4096 slots */
+	dev_key.queue_id = ctx->queue_mapping;
+	dev_key.slot = slot;
+
+	dev_val = bpf_map_lookup_elem(&dev_flow_table, &dev_key);
+	if (dev_val) {
+		/*
+		 * Check if migration is safe.
+		 * In a real implementation, we would check the queue tail
+		 * to ensure in-order delivery. For this sample, we allow
+		 * migration if the CPU is different.
+		 */
+		if (dev_val->cpu != target_cpu) {
+			/* Migration allowed - update dev flow table */
+			dev_val->cpu = target_cpu;
+		}
+		dev_val->last_used = bpf_ktime_get_ns();
+	} else {
+		/* First time seeing this flow on this queue */
+		struct bpf_rfs_dev_flow_val new_val = {
+			.cpu = target_cpu,
+			.last_qtail = 0,
+			.last_used = bpf_ktime_get_ns()
+		};
+		bpf_map_update_elem(&dev_flow_table, &dev_key, &new_val, BPF_ANY);
+	}
+
+	return target_cpu;
+}
+
+char _license[] SEC("license") = "GPL";
diff --git a/samples/bpf/bpf_rfs_user.c b/samples/bpf/bpf_rfs_user.c
new file mode 100644
index 000000000000..16531ca12760
--- /dev/null
+++ b/samples/bpf/bpf_rfs_user.c
@@ -0,0 +1,150 @@
+// SPDX-License-Identifier: GPL-2.0-or-later
+/*
+ * Sample user space program for BPF-RFS
+ *
+ * This program loads and attaches a BPF-RFS program to a network device.
+ */
+
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <unistd.h>
+#include <errno.h>
+#include <linux/bpf.h>
+#include <linux/rfs_bpf.h>
+#include <bpf/libbpf.h>
+#include <bpf/bpf.h>
+#include <net/if.h>
+
+static void usage(const char *prog)
+{
+	fprintf(stderr, "Usage: %s <ifname> [prog_path]\n", prog);
+	fprintf(stderr, "  ifname:    Network interface name (e.g., eth0)\n");
+	fprintf(stderr, "  prog_path: Path to BPF object file (default: bpf_rfs_kern.o)\n");
+}
+
+int main(int argc, char **argv)
+{
+	struct bpf_object *obj = NULL;
+	struct bpf_program *prog = NULL;
+	struct bpf_link *link = NULL;
+	struct bpf_map *sock_flow_map;
+	struct bpf_map *cpu_online_map;
+	const char *ifname;
+	const char *prog_path = "bpf_rfs_kern.o";
+	int ifindex;
+	int ret = 0;
+	int i;
+
+	if (argc < 2) {
+		usage(argv[0]);
+		return 1;
+	}
+
+	ifname = argv[1];
+	if (argc >= 3)
+		prog_path = argv[2];
+
+	/* Get interface index */
+	ifindex = if_nametoindex(ifname);
+	if (!ifindex) {
+		fprintf(stderr, "Failed to get ifindex for %s: %s\n",
+			ifname, strerror(errno));
+		return 1;
+	}
+
+	printf("Loading BPF-RFS program from %s...\n", prog_path);
+
+	/* Load BPF object */
+	obj = bpf_object__open_file(prog_path, NULL);
+	if (libbpf_get_error(obj)) {
+		fprintf(stderr, "Failed to open BPF object: %ld\n",
+			libbpf_get_error(obj));
+		return 1;
+	}
+
+	/* Load the program */
+	ret = bpf_object__load(obj);
+	if (ret) {
+		fprintf(stderr, "Failed to load BPF object: %d\n", ret);
+		goto cleanup;
+	}
+
+	/* Find the RFS program */
+	prog = bpf_object__find_program_by_name(obj, "rfs_select_cpu");
+	if (!prog) {
+		fprintf(stderr, "Failed to find rfs_select_cpu program\n");
+		ret = -ENOENT;
+		goto cleanup;
+	}
+
+	/* Initialize CPU online map */
+	cpu_online_map = bpf_object__find_map_by_name(obj, "cpu_online_map");
+	if (cpu_online_map) {
+		int map_fd = bpf_map__fd(cpu_online_map);
+		int nr_cpus = libbpf_num_possible_cpus();
+
+		for (i = 0; i < nr_cpus && i < 256; i++) {
+			__u32 key = i;
+			__u32 value = 1;  /* Mark all possible CPUs as online */
+			bpf_map_update_elem(map_fd, &key, &value, BPF_ANY);
+		}
+		printf("Initialized %d CPUs as online\n", nr_cpus);
+	}
+
+	/* Initialize sock flow table with some sample entries */
+	sock_flow_map = bpf_object__find_map_by_name(obj, "sock_flow_table");
+	if (sock_flow_map) {
+		int map_fd = bpf_map__fd(sock_flow_map);
+		struct bpf_rfs_sock_flow_key key;
+		struct bpf_rfs_sock_flow_val val;
+
+		/* Add a sample flow entry - hash 0x12345678 -> CPU 1 */
+		key.hash = 0x12345678;
+		val.cpu = 1;
+		val.timestamp = 0;
+		val.pid = getpid();
+		val.reserved = 0;
+
+		ret = bpf_map_update_elem(map_fd, &key, &val, BPF_ANY);
+		if (ret) {
+			fprintf(stderr, "Failed to add sample flow entry: %d\n", ret);
+		}
+		printf("Added sample flow entry: hash 0x%08x -> CPU %u\n",
+		       key.hash, val.cpu);
+	}
+
+	/* Attach the program using bpf_link */
+	printf("Attaching BPF-RFS program to %s (ifindex %d)...\n", ifname, ifindex);
+
+	/* Use BPF link to attach */
+	DECLARE_LIBBPF_OPTS(bpf_link_create_opts, link_opts);
+	link_opts.prog_fd = bpf_program__fd(prog);
+	link_opts.target_ifindex = ifindex;
+	link_opts.attach_type = BPF_RFS_INGRESS;
+
+	link = bpf_program__attach(prog);
+	if (libbpf_get_error(link)) {
+		fprintf(stderr, "Failed to attach BPF program: %ld\n",
+			libbpf_get_error(link));
+		link = NULL;
+		ret = -1;
+		goto cleanup;
+	}
+
+	printf("BPF-RFS program attached successfully!\n");
+	printf("Press Ctrl+C to detach and exit...\n");
+
+	/* Keep running until interrupted */
+	while (1) {
+		sleep(1);
+	}
+
+cleanup:
+	if (link)
+		bpf_link__destroy(link);
+	if (obj)
+		bpf_object__close(obj);
+
+	return ret;
+}
