diff --git a/include/net/rfs_bpf.h b/include/net/rfs_bpf.h
new file mode 100644
index 000000000000..dcd428a40e34
--- /dev/null
+++ b/include/net/rfs_bpf.h
@@ -0,0 +1,58 @@
+/* SPDX-License-Identifier: GPL-2.0-or-later */
+#ifndef _NET_RFS_BPF_H
+#define _NET_RFS_BPF_H
+
+#include <linux/bpf.h>
+#include <linux/bpf_mprog.h>
+#include <linux/static_key.h>
+#include <linux/skbuff.h>
+#include <net/net_namespace.h>
+
+/* Kernel internal RFS context - passed to BPF programs */
+struct bpf_rfs_ctx_kern {
+	struct sk_buff *skb;
+	u32 hash;
+	u32 current_cpu;
+	struct net_device *dev;
+	int selected_cpu;
+	bool cpu_selected;
+};
+
+/* BPF-RFS entry - similar to tcx_entry */
+struct bpf_rfs_entry {
+	struct bpf_mprog_bundle bundle;
+	struct rcu_head rcu;
+};
+
+/* BPF-RFS link structure */
+struct bpf_rfs_link {
+	struct bpf_link link;
+	struct net_device *dev;
+};
+
+#ifdef CONFIG_BPF_RFS
+extern struct static_key_false bpf_rfs_needed;
+
+static inline bool bpf_rfs_is_needed(void)
+{
+	return static_branch_unlikely(&bpf_rfs_needed);
+}
+
+/* Core functions */
+int bpf_rfs_prog_attach(const union bpf_attr *attr, struct bpf_prog *prog);
+int bpf_rfs_prog_detach(const union bpf_attr *attr, struct bpf_prog *prog);
+int bpf_rfs_prog_query(const union bpf_attr *attr, union bpf_attr __user *uattr);
+int bpf_rfs_link_attach(const union bpf_attr *attr, struct bpf_prog *prog);
+void bpf_rfs_link_release(struct bpf_link *link);
+int bpf_rfs_run(const struct bpf_mprog_entry *entry, struct sk_buff *skb);
+void dev_bpf_rfs_uninstall(struct net_device *dev);
+
+#else /* !CONFIG_BPF_RFS */
+
+static inline bool bpf_rfs_is_needed(void) { return false; }
+static inline int bpf_rfs_run(const struct bpf_mprog_entry *entry, struct sk_buff *skb) { return -1; }
+static inline void dev_bpf_rfs_uninstall(struct net_device *dev) {}
+
+#endif /* CONFIG_BPF_RFS */
+
+#endif /* _NET_RFS_BPF_H */
