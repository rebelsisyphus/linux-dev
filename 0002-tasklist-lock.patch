new file mode 100644
index 000000000000..848d075a2119
--- /dev/null
+++ b/kernel/fork_numa.c
@@ -0,0 +1,276 @@
+// SPDX-License-Identifier: GPL-2.0-or-later
+/*
+ * NUMA-aware tasklist implementation
+ *
+ * This file implements per-NUMA-node tasklist locks to reduce
+ * contention on systems with many CPUs.
+ */
+
+#include <linux/sched/task_numa.h>
+#include <linux/sched/task.h>
+#include <linux/slab.h>
+#include <linux/rcupdate.h>
+#include <linux/numa.h>
+#include <linux/nodemask.h>
+#include <linux/cpumask.h>
+#include <linux/spinlock.h>
+#include <linux/atomic.h>
+#include <linux/export.h>
+
+#ifdef CONFIG_NUMA_TASKLIST
+
+/*
+ * Global NUMA tasklist structure
+ */
+struct numa_global_tasklist numa_tasklist;
+
+/*
+ * Original tasklist_lock - kept for compatibility during transition
+ * This will be removed once all callers are migrated
+ */
+extern rwlock_t tasklist_lock;
+
+/*
+ * Initialize NUMA-aware tasklist
+ */
+void __init numa_tasklist_init(void)
+{
+	int node;
+
+	/* Initialize per-node task lists */
+	for_each_node_mask(node, node_possible_map) {
+		rwlock_init(&numa_tasklist.per_node[node].lock);
+		INIT_LIST_HEAD(&numa_tasklist.per_node[node].tasks);
+		numa_tasklist.per_node[node].nr_tasks = 0;
+	}
+
+	/* Initialize global lock */
+	rwlock_init(&numa_tasklist.global_lock);
+	atomic_long_set(&numa_tasklist.nr_total_tasks, 0);
+	numa_tasklist.active_nodes = node_possible_map;
+
+	pr_info("NUMA-aware tasklist initialized with %d nodes\n",
+		nodes_weight(node_possible_map));
+}
+
+/*
+ * Add a task to a specific NUMA node's task list
+ */
+void numa_tasklist_add(struct task_struct *p, int node)
+{
+	struct numa_tasklist *ntl;
+
+	if (unlikely(node < 0 || node >= MAX_NUMA_NODES))
+		node = 0;
+
+	ntl = &numa_tasklist.per_node[node];
+
+	write_lock_irq(&ntl->lock);
+	list_add_tail_rcu(&p->tasks_node, &ntl->tasks);
+	ntl->nr_tasks++;
+	write_unlock_irq(&ntl->lock);
+
+	/* Update task's NUMA node */
+	task_set_numa_node(p, node);
+
+	/* Update global count */
+	atomic_long_inc(&numa_tasklist.nr_total_tasks);
+}
+EXPORT_SYMBOL_GPL(numa_tasklist_add);
+
+/*
+ * Remove a task from its NUMA node's task list
+ */
+void numa_tasklist_del(struct task_struct *p)
+{
+	int node = task_numa_node(p);
+	struct numa_tasklist *ntl;
+
+	if (unlikely(node < 0 || node >= MAX_NUMA_NODES))
+		node = 0;
+
+	ntl = &numa_tasklist.per_node[node];
+
+	write_lock_irq(&ntl->lock);
+	list_del_rcu(&p->tasks_node);
+	ntl->nr_tasks--;
+	write_unlock_irq(&ntl->lock);
+
+	/* Update global count */
+	atomic_long_dec(&numa_tasklist.nr_total_tasks);
+}
+EXPORT_SYMBOL_GPL(numa_tasklist_del);
+
+/*
+ * Migrate a task to a different NUMA node
+ * This is called when a task is moved to a different node
+ */
+void numa_tasklist_migrate(struct task_struct *p, int new_node)
+{
+	int old_node = task_numa_node(p);
+	struct numa_tasklist *old_ntl, *new_ntl;
+
+	if (unlikely(new_node < 0 || new_node >= MAX_NUMA_NODES))
+		new_node = 0;
+
+	if (old_node == new_node)
+		return;
+
+	old_ntl = &numa_tasklist.per_node[old_node];
+	new_ntl = &numa_tasklist.per_node[new_node];
+
+	/*
+	 * Lock ordering: always lock lower node first to avoid deadlock
+	 */
+	if (old_node < new_node) {
+		write_lock_irq(&old_ntl->lock);
+		write_lock(&new_ntl->lock);
+	} else {
+		write_lock_irq(&new_ntl->lock);
+		write_lock(&old_ntl->lock);
+	}
+
+	/* Remove from old node */
+	list_del_rcu(&p->tasks_node);
+	old_ntl->nr_tasks--;
+
+	/* Add to new node */
+	list_add_tail_rcu(&p->tasks_node, &new_ntl->tasks);
+	new_ntl->nr_tasks++;
+
+	task_set_numa_node(p, new_node);
+
+	if (old_node < new_node) {
+		write_unlock(&new_ntl->lock);
+		write_unlock_irq(&old_ntl->lock);
+	} else {
+		write_unlock(&old_ntl->lock);
+		write_unlock_irq(&new_ntl->lock);
+	}
+}
+EXPORT_SYMBOL_GPL(numa_tasklist_migrate);
+
+/*
+ * Find task by PID - searches all NUMA nodes
+ *
+ * This uses RCU for lockless lookup and falls back to
+ * per-node locks if needed.
+ */
+struct task_struct *numa_find_task_by_pid(pid_t pid)
+{
+	struct task_struct *p;
+	int node;
+
+	/*
+	 * First try RCU lookup on all nodes
+	 * This is lockless but may miss tasks being added/removed
+	 */
+	rcu_read_lock();
+	for_each_numa_node(node) {
+		for_each_task_numa_node(p, node) {
+			if (p->pid == pid) {
+				if (refcount_inc_not_zero(&p->usage)) {
+					rcu_read_unlock();
+					return p;
+				}
+			}
+		}
+	}
+	rcu_read_unlock();
+
+	return NULL;
+}
+EXPORT_SYMBOL_GPL(numa_find_task_by_pid);
+
+/*
+ * Count total tasks across all nodes
+ */
+long numa_tasklist_nr_tasks(void)
+{
+	return atomic_long_read(&numa_tasklist.nr_total_tasks);
+}
+EXPORT_SYMBOL_GPL(numa_tasklist_nr_tasks);
+
+/*
+ * Count tasks on a specific node
+ */
+unsigned long numa_tasklist_nr_tasks_node(int node)
+{
+	struct numa_tasklist *ntl;
+	unsigned long count;
+
+	if (unlikely(node < 0 || node >= MAX_NUMA_NODES))
+		return 0;
+
+	ntl = &numa_tasklist.per_node[node];
+
+	read_lock(&ntl->lock);
+	count = ntl->nr_tasks;
+	read_unlock(&ntl->lock);
+
+	return count;
+}
+EXPORT_SYMBOL_GPL(numa_tasklist_nr_tasks_node);
+
+/*
+ * Compatibility wrapper for for_each_process
+ * This iterates over all tasks across all NUMA nodes
+ */
+struct task_struct *numa_next_task(struct task_struct *p)
+{
+	int node, nn;
+	struct task_struct *next = NULL;
+
+	if (!p)
+		return NULL;
+
+	node = task_numa_node(p);
+
+	/* Try to find next task in current node */
+	rcu_read_lock();
+	next = list_next_or_null_rcu(&numa_tasklist.per_node[node].tasks,
+				     &p->tasks_node, struct task_struct,
+				     tasks_node);
+
+	/* If no more tasks in current node, move to next node */
+	if (!next) {
+		for_each_numa_node(nn) {
+			if (nn <= node)
+				continue;
+			if (!list_empty(&numa_tasklist.per_node[nn].tasks)) {
+				next = list_first_or_null_rcu(
+					&numa_tasklist.per_node[nn].tasks,
+					struct task_struct, tasks_node);
+				if (next)
+					break;
+			}
+		}
+	}
+
+	if (next && !refcount_inc_not_zero(&next->usage))
+		next = NULL;
+
+	rcu_read_unlock();
+
+	return next;
+}
+EXPORT_SYMBOL_GPL(numa_next_task);
+
+/*
+ * Debug function to dump NUMA tasklist statistics
+ */
+void numa_tasklist_dump_stats(void)
+{
+	int node;
+
+	pr_info("NUMA Tasklist Statistics:\n");
+	pr_info("  Total tasks: %ld\n", numa_tasklist_nr_tasks());
+
+	for_each_numa_node(node) {
+		pr_info("  Node %d: %lu tasks\n",
+			node, numa_tasklist_nr_tasks_node(node));
+	}
+}
+EXPORT_SYMBOL_GPL(numa_tasklist_dump_stats);
+
+#endif /* CONFIG_NUMA_TASKLIST */
