diff --git a/include/linux/sched/task_numa.h b/include/linux/sched/task_numa.h
new file mode 100644
index 000000000000..7cc2a4866e94
--- /dev/null
+++ b/include/linux/sched/task_numa.h
@@ -0,0 +1,210 @@
+/* SPDX-License-Identifier: GPL-2.0 */
+#ifndef _LINUX_SCHED_TASK_NUMA_H
+#define _LINUX_SCHED_TASK_NUMA_H
+
+#include <linux/nodemask.h>
+#include <linux/spinlock.h>
+#include <linux/rculist.h>
+#include <linux/cpumask.h>
+#include <linux/smp.h>
+
+#ifdef CONFIG_NUMA_TASKLIST
+
+/*
+ * NUMA-aware tasklist_lock implementation
+ *
+ * This splits the global tasklist_lock into per-NUMA-node locks
+ * to reduce contention on systems with many CPUs.
+ *
+ * Each NUMA node maintains:
+ * - Its own task list (for tasks created on that node)
+ * - Its own rwlock for local operations
+ * - A global lock for cross-node operations
+ */
+
+#include <linux/numa.h>
+
+/* Maximum number of NUMA nodes supported */
+#ifndef MAX_NUMA_NODES
+#define MAX_NUMA_NODES		MAX_NUMNODES
+#endif
+
+/*
+ * Per-NUMA-node task list structure
+ */
+struct numa_tasklist {
+	rwlock_t		lock;
+	struct list_head	tasks;
+	unsigned long		nr_tasks;
+};
+
+/*
+ * Global NUMA tasklist structure
+ */
+struct numa_global_tasklist {
+	/* Per-node task lists */
+	struct numa_tasklist	per_node[MAX_NUMA_NODES];
+
+	/* Global lock for cross-node operations */
+	rwlock_t		global_lock;
+
+	/* Total task count */
+	atomic_long_t		nr_total_tasks;
+
+	/* Node mask for iteration */
+	nodemask_t		active_nodes;
+};
+
+extern struct numa_global_tasklist numa_tasklist;
+
+/*
+ * NUMA node ID for task - stored in task_struct
+ */
+static inline int task_numa_node(struct task_struct *p)
+{
+	return p->numa_node_id;
+}
+
+static inline void task_set_numa_node(struct task_struct *p, int node)
+{
+	p->numa_node_id = node;
+}
+
+/*
+ * Lock operations for NUMA-aware tasklist
+ */
+
+/* Lock a specific node's tasklist */
+static inline void numa_tasklist_read_lock(int node)
+{
+	if (unlikely(node < 0 || node >= MAX_NUMA_NODES))
+		node = 0;
+	read_lock(&numa_tasklist.per_node[node].lock);
+}
+
+static inline void numa_tasklist_read_unlock(int node)
+{
+	if (unlikely(node < 0 || node >= MAX_NUMA_NODES))
+		node = 0;
+	read_unlock(&numa_tasklist.per_node[node].lock);
+}
+
+static inline void numa_tasklist_write_lock(int node)
+{
+	if (unlikely(node < 0 || node >= MAX_NUMA_NODES))
+		node = 0;
+	write_lock_irq(&numa_tasklist.per_node[node].lock);
+}
+
+static inline void numa_tasklist_write_unlock(int node)
+{
+	if (unlikely(node < 0 || node >= MAX_NUMA_NODES))
+		node = 0;
+	write_unlock_irq(&numa_tasklist.per_node[node].lock);
+}
+
+/* Global lock for cross-node operations */
+static inline void numa_tasklist_global_read_lock(void)
+{
+	read_lock(&numa_tasklist.global_lock);
+}
+
+static inline void numa_tasklist_global_read_unlock(void)
+{
+	read_unlock(&numa_tasklist.global_lock);
+}
+
+static inline void numa_tasklist_global_write_lock(void)
+{
+	write_lock_irq(&numa_tasklist.global_lock);
+}
+
+static inline void numa_tasklist_global_write_unlock(void)
+{
+	write_unlock_irq(&numa_tasklist.global_lock);
+}
+
+/*
+ * Iteration macros for NUMA-aware tasklist
+ */
+
+/* Iterate over all nodes */
+#define for_each_numa_node(node)					\
+	for ((node) = first_node(numa_tasklist.active_nodes);		\
+	     (node) < MAX_NUMA_NODES;					\
+	     (node) = next_node((node), numa_tasklist.active_nodes))
+
+/* Iterate over tasks in a specific node */
+#define for_each_task_numa_node(p, node)				\
+	list_for_each_entry_rcu((p), &numa_tasklist.per_node[(node)].tasks,	\
+				tasks_node)
+
+/* Iterate over all tasks across all nodes */
+#define for_each_task_all_nodes(p)					\
+	for_each_numa_node(node_numa)					\
+		for_each_task_numa_node((p), node_numa)
+
+/*
+ * Backward compatibility macros
+ * These map to NUMA-aware versions when CONFIG_NUMA_TASKLIST is enabled
+ */
+
+#define tasklist_read_lock_numa(node)		numa_tasklist_read_lock(node)
+#define tasklist_read_unlock_numa(node)		numa_tasklist_read_unlock(node)
+#define tasklist_write_lock_numa(node)		numa_tasklist_write_lock(node)
+#define tasklist_write_unlock_numa(node)	numa_tasklist_write_unlock(node)
+
+/*
+ * Initialization
+ */
+void __init numa_tasklist_init(void);
+
+/*
+ * Task list operations
+ */
+void numa_tasklist_add(struct task_struct *p, int node);
+void numa_tasklist_del(struct task_struct *p);
+void numa_tasklist_migrate(struct task_struct *p, int new_node);
+
+/*
+ * Find task by PID (searches all nodes)
+ */
+struct task_struct *numa_find_task_by_pid(pid_t pid);
+
+/*
+ * Get current CPU's NUMA node for task operations
+ */
+static inline int current_numa_node(void)
+{
+	return cpu_to_node(smp_processor_id());
+}
+
+#else /* !CONFIG_NUMA_TASKLIST */
+
+/*
+ * Fallback to original implementation when NUMA support is disabled
+ */
+#include <linux/sched/task.h>
+
+static inline void numa_tasklist_init(void) { }
+static inline void numa_tasklist_add(struct task_struct *p, int node) { }
+static inline void numa_tasklist_del(struct task_struct *p) { }
+static inline void numa_tasklist_migrate(struct task_struct *p, int new_node) { }
+
+static inline int task_numa_node(struct task_struct *p)
+{
+	return 0;
+}
+
+static inline void task_set_numa_node(struct task_struct *p, int node)
+{
+}
+
+static inline int current_numa_node(void)
+{
+	return 0;
+}
+
+#endif /* CONFIG_NUMA_TASKLIST */
+
+#endif /* _LINUX_SCHED_TASK_NUMA_H */
