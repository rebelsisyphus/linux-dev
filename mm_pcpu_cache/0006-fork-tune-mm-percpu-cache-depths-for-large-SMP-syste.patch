From 4dca6afee70e13847ee7391a397e2153aa408199 Mon Sep 17 00:00:00 2001
From: Dong Chenchen <superdcc97@163.com>
Date: Mon, 20 Apr 2026 20:43:32 +0800
Subject: [PATCH 6/7] fork: tune mm percpu cache depths for large SMP systems

On a 320-core / 4-NUMA machine the previous cache depths are
suboptimal:

  - MM_STAT_EXT_CACHE_MAX=16:  the per-CPU tier1 cache rarely hits
    on large systems because fork and exit almost always run on
    different CPUs.  Reducing from 16 to 4 saves per-CPU memory
    (320 CPUs * 12 entries saved * 16 bytes = ~60 KB) with no
    functional impact.

  - MM_STAT_EXT_NODE_CACHE_MAX=128:  with 80 cores per NUMA node
    all doing fork/exit concurrently, burst exit can easily
    overflow 128 entries, falling back to free_percpu which
    contends on pcpu_alloc_mutex.  Increasing from 128 to 512
    absorbs burst traffic at negligible cost (4 nodes * 384
    extra entries * 16 bytes = ~24 KB).

Signed-off-by: Dong Chenchen <superdcc97@163.com>
---
 kernel/fork.c | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/kernel/fork.c b/kernel/fork.c
index 243da6d77da9..c5de8aa5ed12 100644
--- a/kernel/fork.c
+++ b/kernel/fork.c
@@ -638,8 +638,8 @@ static struct kmem_cache *mm_cachep;
  * On a 320-core / 4-NUMA machine, the 4 node-level spinlocks have
  * negligible contention compared to a single pcpu_alloc_mutex.
  */
-#define MM_STAT_EXT_CACHE_MAX	16
-#define MM_STAT_EXT_NODE_CACHE_MAX	128
+#define MM_STAT_EXT_CACHE_MAX	4
+#define MM_STAT_EXT_NODE_CACHE_MAX	512
 
 struct mm_stat_ext_cache {
 	unsigned int count;
