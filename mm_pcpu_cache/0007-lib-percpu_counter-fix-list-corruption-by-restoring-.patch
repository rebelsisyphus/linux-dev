From 479f62de64515897d9e7fa481439f82a71ff534e Mon Sep 17 00:00:00 2001
From: Dong Chenchen <superdcc97@163.com>
Date: Mon, 20 Apr 2026 20:59:07 +0800
Subject: [PATCH 7/7] lib/percpu_counter: fix list corruption by restoring
 list_del/list_add in detach/reinit

The v3 optimisation that removed list_del() from percpu_counter_detach_many()
and list_add() from percpu_counter_reinit_many_pcpu() causes list corruption
on large SMP systems.  The root cause:

  1. detach_many() no longer removes counters from the hotplug list
  2. The mm_struct is returned to the SLUB slab via free_mm()
  3. SLUB recycles the slab object for a new mm_struct allocation
  4. mm_init() does memset(&mm->rss_stat, 0, ...), zeroing list_head
     entries that are still linked into the percpu_counters list
  5. The hotplug list is now corrupted with zeroed prev/next pointers

Fix by restoring list_del in detach_many and INIT_LIST_HEAD + list_add in
reinit_many_pcpu.  This means percpu_counters_lock is taken once on each
of the fork (reinit) and exit (detach) paths, same as v2.  The remaining
v3 optimisations are still intact:

  - percpu_counter_init_many_pcpu no longer does for_each_possible_cpu
    memset zeroing (zeroing moved to mm_stat_ext_cache_put on exit)
  - percpu_counter_reinit_many_pcpu still skips percpu zeroing
  - mm_init no longer does for_each_possible_cpu cid=0 (moved to exit)
---
 lib/percpu_counter.c | 30 ++++++++++++++++++++++++------
 1 file changed, 24 insertions(+), 6 deletions(-)

diff --git a/lib/percpu_counter.c b/lib/percpu_counter.c
index 50ba62842e90..ec20be17c66f 100644
--- a/lib/percpu_counter.c
+++ b/lib/percpu_counter.c
@@ -284,12 +284,11 @@ EXPORT_SYMBOL(percpu_counter_init_many_pcpu);
  *
  * Like percpu_counter_init_many_pcpu(), but for counters that were
  * previously initialised and then detached via percpu_counter_detach_many().
- * Because the counters were never removed from the hotplug list (detach
- * only NULLs the percpu pointers and deactivates debug objects), this
- * function reuses the existing list_head and simply re-attaches the
- * percpu data area and re-activates debug objects.  This avoids taking
- * percpu_counters_lock, eliminating a global contention point on large
- * SMP systems.
+ * The detach step removes counters from the hotplug list (necessary
+ * because the containing mm_struct may be freed and reallocated by SLUB,
+ * which would corrupt the list through slab reuse).  This function
+ * reinitialises the spinlock, count, and percpu pointers, re-activates
+ * debug objects, and re-adds the counters to the hotplug list.
  *
  * The caller guarantees that the percpu values are already zeroed.
  */
@@ -297,6 +296,7 @@ int percpu_counter_reinit_many_pcpu(struct percpu_counter *fbc, s64 amount,
 				     s32 __percpu *counters, u32 nr_counters,
 				     struct lock_class_key *key)
 {
+	unsigned long flags __maybe_unused;
 	size_t counter_size;
 	u32 i;
 
@@ -305,12 +305,22 @@ int percpu_counter_reinit_many_pcpu(struct percpu_counter *fbc, s64 amount,
 	for (i = 0; i < nr_counters; i++) {
 		raw_spin_lock_init(&fbc[i].lock);
 		lockdep_set_class(&fbc[i].lock, key);
+#ifdef CONFIG_HOTPLUG_CPU
+		INIT_LIST_HEAD(&fbc[i].list);
+#endif
 		fbc[i].count = amount;
 		fbc[i].counters = (void __percpu *)counters + i * counter_size;
 
 		debug_percpu_counter_activate(&fbc[i]);
 	}
 
+#ifdef CONFIG_HOTPLUG_CPU
+	spin_lock_irqsave(&percpu_counters_lock, flags);
+	for (i = 0; i < nr_counters; i++)
+		list_add(&fbc[i].list, &percpu_counters);
+	spin_unlock_irqrestore(&percpu_counters_lock, flags);
+#endif
+
 	return 0;
 }
 EXPORT_SYMBOL(percpu_counter_reinit_many_pcpu);
@@ -330,6 +340,7 @@ EXPORT_SYMBOL(percpu_counter_reinit_many_pcpu);
  */
 void percpu_counter_detach_many(struct percpu_counter *fbc, u32 nr_counters)
 {
+	unsigned long flags __maybe_unused;
 	u32 i;
 
 	if (WARN_ON_ONCE(!fbc))
@@ -341,6 +352,13 @@ void percpu_counter_detach_many(struct percpu_counter *fbc, u32 nr_counters)
 	for (i = 0; i < nr_counters; i++)
 		debug_percpu_counter_deactivate(&fbc[i]);
 
+#ifdef CONFIG_HOTPLUG_CPU
+	spin_lock_irqsave(&percpu_counters_lock, flags);
+	for (i = 0; i < nr_counters; i++)
+		list_del(&fbc[i].list);
+	spin_unlock_irqrestore(&percpu_counters_lock, flags);
+#endif
+
 	for (i = 0; i < nr_counters; i++)
 		fbc[i].counters = NULL;
 }
-- 
