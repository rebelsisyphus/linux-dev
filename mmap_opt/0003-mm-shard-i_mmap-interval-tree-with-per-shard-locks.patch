+int i_mmap_shard_init(struct address_space *mapping, gfp_t gfp);
+void i_mmap_shard_free(struct address_space *mapping);
+void i_mmap_shard_promote(struct address_space *mapping);
+
+/* Iterate all VMAs across all shards (or single tree when non-sharded) */
+#define vma_interval_tree_foreach_sharded(vma, mapping, start, last)		\
+	for (int __shard = 0; __shard < i_mmap_nr_shards(mapping); __shard++)	\
+		vma_interval_tree_foreach(vma,					\
+			i_mmap_shard_tree(mapping, __shard), start, last)
+#endif /* CONFIG_MM_IMMAP_SHARD */
