@@ -544,8 +650,45 @@ static inline void i_mmap_assert_locked(struct address_space *mapping)
 
 static inline void i_mmap_assert_write_locked(struct address_space *mapping)
 {
-	lockdep_assert_held_write(&mapping->i_mmap_rwsem);
+	if (i_mmap_is_sharded(mapping))
+		lockdep_assert_held(&mapping->i_mmap_rwsem);
+	else
+		lockdep_assert_held_write(&mapping->i_mmap_rwsem);
+}
+
+#ifdef CONFIG_MM_IMMAP_SHARD
+/*
+ * i_mmap_lock_write_promote() - Acquire i_mmap write lock, promoting to
+ * sharded mode if contention is detected.
+ *
+ * For non-sharded mappings, uses trylock first. If trylock fails enough
+ * times, promotes the mapping to sharded mode. For already-sharded
+ * mappings, simply acquires the top-level read lock (caller must also
+ * acquire the per-shard lock).
+ */
+static inline void i_mmap_lock_write_promote(struct address_space *mapping)
+{
+	if (i_mmap_is_sharded(mapping)) {
+		i_mmap_lock_write(mapping);
+		return;
+	}
+
+	if (i_mmap_trylock_write(mapping))
+		return;
+
+	if (atomic_inc_return(&mapping->i_mmap_trylock_fails) >=
+	    I_MMAP_PROMOTE_THRESHOLD) {
+		down_write(&mapping->i_mmap_rwsem);
+		if (!i_mmap_is_sharded(mapping))
+			i_mmap_shard_promote(mapping);
+		up_write(&mapping->i_mmap_rwsem);
+		/* Now sharded: re-acquire with the new protocol */
+		i_mmap_lock_write(mapping);
+	} else {
+		down_write(&mapping->i_mmap_rwsem);
+	}
 }
+#endif /* CONFIG_MM_IMMAP_SHARD */
 
