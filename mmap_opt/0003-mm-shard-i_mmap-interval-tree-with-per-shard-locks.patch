+static inline int i_mmap_nr_shards(const struct address_space *mapping)
+{
+	return 1;
+}
+static inline unsigned int i_mmap_vma_shard(const struct vm_area_struct *vma)
+{
+	return 0;
+}
+static inline void i_mmap_shard_lock_write(struct address_space *mapping,
+					   unsigned int shard) {}
+static inline void i_mmap_shard_unlock_write(struct address_space *mapping,
+					     unsigned int shard) {}
+static inline struct rb_root_cached *i_mmap_shard_tree(
+	struct address_space *mapping, unsigned int shard)
+{
+	return &mapping->i_mmap;
+}
+#define vma_interval_tree_foreach_sharded(vma, mapping, start, last) \
+	vma_interval_tree_foreach(vma, &(mapping)->i_mmap, start, last)
+
