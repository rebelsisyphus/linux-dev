+#ifdef CONFIG_MM_IMMAP_SHARD
+/*
+ * i_mmap_shard_init() - Allocate shard structures for a mapping.
+ * @mapping: The mapping to shard.
+ * @gfp: Allocation flags.
+ *
+ * Called when a mapping first becomes file-backed-mmap'd.
+ * On failure, the mapping remains non-sharded (fallback to single lock).
+ */
+int i_mmap_shard_init(struct address_space *mapping, gfp_t gfp)
+{
+	struct i_mmap_shard *shards;
+	int i;
+
+	if (mapping->i_mmap_shards)
+		return 0;
+
+	shards = kcalloc(I_MMAP_NR_SHARDS, sizeof(*shards), gfp);
+	if (!shards)
+		return -ENOMEM;
+
+	for (i = 0; i < I_MMAP_NR_SHARDS; i++) {
+		shards[i].tree = RB_ROOT_CACHED;
+		init_rwsem(&shards[i].rwsem);
+	}
+
+	/*
+	 * Publish atomically. If another thread raced us and already
+	 * installed its allocation, free ours and use theirs.
+	 */
+	if (cmpxchg(&mapping->i_mmap_shards, NULL, shards)) {
+		kfree(shards);
+	}
+	return 0;
+}
+
+void i_mmap_shard_free(struct address_space *mapping)
+{
+	struct i_mmap_shard *shards;
+
+	shards = mapping->i_mmap_shards;
+	if (!shards)
+		return;
+
+	mapping->i_mmap_shards = NULL;
+	/* Ensure no concurrent access before freeing */
+	synchronize_rcu();
+	kfree(shards);
+}
+
+/*
+ * i_mmap_shard_promote() - Promote a centralized mapping to sharded mode.
+ * @mapping: The mapping to promote (must NOT already be sharded).
+ *
+ * Caller must hold i_mmap_rwsem for write (exclusive).  All existing VMAs
+ * are migrated from the centralized interval tree to per-shard trees.
+ * After this, i_mmap_is_sharded() returns true and the lock macros switch
+ * to the sharded protocol.
+ */
+void i_mmap_shard_promote(struct address_space *mapping)
+{
+	struct i_mmap_shard *shards;
+	struct vm_area_struct *vma;
+	unsigned long start = 0;
+	int i;
+
+	if (mapping->i_mmap_shards)
+		return;
+
+	shards = kcalloc(I_MMAP_NR_SHARDS, sizeof(*shards), GFP_KERNEL);
+	if (!shards)
+		return;
+
+	for (i = 0; i < I_MMAP_NR_SHARDS; i++) {
+		shards[i].tree = RB_ROOT_CACHED;
+		init_rwsem(&shards[i].rwsem);
+	}
+
+	/*
+	 * Migrate all VMAs from the centralized tree to per-shard trees.
+	 * Restart iteration after each removal since the tree is being
+	 * modified.  Use vma->vm_end as the new search start to skip
+	 * already-processed VMAs.
+	 */
+	while ((vma = vma_interval_tree_iter_first(&mapping->i_mmap,
+						   start, ULONG_MAX))) {
+		unsigned int idx = (vma->vm_pgoff ^
+				   (vma->vm_pgoff >> PAGE_SHIFT)) %
+				  I_MMAP_NR_SHARDS;
+
+		vma_interval_tree_remove(vma, &mapping->i_mmap);
+		vma->i_mmap_shard_idx = idx;
+		vma_interval_tree_insert(vma, &shards[idx].tree);
+		start = vma->vm_end;
+	}
+
+	/* Publish atomically (cmpxchg handles concurrent promote races) */
+	if (cmpxchg(&mapping->i_mmap_shards, NULL, shards)) {
+		/* Another thread already promoted; free our allocation */
+		for (i = 0; i < I_MMAP_NR_SHARDS; i++) {
+			/* Move VMAs from our shards to the winner's shards */
+			start = 0;
+			while ((vma = vma_interval_tree_iter_first(
+					&shards[i].tree, start, ULONG_MAX))) {
+				vma_interval_tree_remove(vma, &shards[i].tree);
+				vma_interval_tree_insert(vma,
+					&mapping->i_mmap_shards[i].tree);
+				start = vma->vm_end;
+			}
+		}
+		kfree(shards);
+	}
+}
+#endif /* CONFIG_MM_IMMAP_SHARD */
+
