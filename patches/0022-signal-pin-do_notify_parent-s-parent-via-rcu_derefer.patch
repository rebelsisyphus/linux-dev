From d124b2a7759cd4423cf0e064590c91f103e947b4 Mon Sep 17 00:00:00 2001
From: Dong Chenchen <superdcc97@163.com>
Date: Thu, 9 Apr 2026 19:41:30 +0800
Subject: [PATCH 22/27] signal: pin do_notify_parent()'s parent via
 rcu_dereference + refcount
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

do_notify_parent() used to rely on the caller holding tasklist_lock to
keep tsk->parent alive across the siglock critical section.  With
forget_original_parent() now using fine-grained task_lock, the parent
pointer can be rewritten concurrently.  Snapshot it under RCU and take
a reference for the duration of the notify; drop the reference before
returning.

No functional change yet — tasklist_lock is still held by exit_notify().
This commit lets later commits drop that outer lock.

Signed-off-by: Dong Chenchen <superdcc97@163.com>

---
 kernel/signal.c | 36 +++++++++++++++++++-----------------
 1 file changed, 19 insertions(+), 17 deletions(-)

diff --git a/kernel/signal.c b/kernel/signal.c
index d65d0fe24bfb..757776309361 100644
--- a/kernel/signal.c
+++ b/kernel/signal.c
@@ -2167,6 +2167,7 @@ void do_notify_pidfd(struct task_struct *task)
  */
 bool do_notify_parent(struct task_struct *tsk, int sig)
 {
+	struct task_struct *parent;
 	struct kernel_siginfo info;
 	unsigned long flags;
 	struct sighand_struct *psig;
@@ -2181,6 +2182,17 @@ bool do_notify_parent(struct task_struct *tsk, int sig)
 	WARN_ON_ONCE(!tsk->ptrace &&
 	       (tsk->group_leader != tsk || !thread_group_empty(tsk)));
 
+	/*
+	 * Snapshot and pin tsk->parent under RCU.  Since the fork/exit hot
+	 * paths no longer hold tasklist_lock exclusively, the parent can be
+	 * reparented concurrently by forget_original_parent(); rcu_dereference
+	 * + get_task_struct() keeps the snapshot alive across siglock.
+	 */
+	rcu_read_lock();
+	parent = rcu_dereference(tsk->parent);
+	get_task_struct(parent);
+	rcu_read_unlock();
+
 	/* ptraced, or group-leader without sub-threads */
 	do_notify_pidfd(tsk);
 
@@ -2189,27 +2201,16 @@ bool do_notify_parent(struct task_struct *tsk, int sig)
 		 * This is only possible if parent == real_parent.
 		 * Check if it has changed security domain.
 		 */
-		if (tsk->parent_exec_id != READ_ONCE(tsk->parent->self_exec_id))
+		if (tsk->parent_exec_id != READ_ONCE(parent->self_exec_id))
 			sig = SIGCHLD;
 	}
 
 	clear_siginfo(&info);
 	info.si_signo = sig;
 	info.si_errno = 0;
-	/*
-	 * We are under tasklist_lock here so our parent is tied to
-	 * us and cannot change.
-	 *
-	 * task_active_pid_ns will always return the same pid namespace
-	 * until a task passes through release_task.
-	 *
-	 * write_lock() currently calls preempt_disable() which is the
-	 * same as rcu_read_lock(), but according to Oleg, this is not
-	 * correct to rely on this
-	 */
 	rcu_read_lock();
-	info.si_pid = task_pid_nr_ns(tsk, task_active_pid_ns(tsk->parent));
-	info.si_uid = from_kuid_munged(task_cred_xxx(tsk->parent, user_ns),
+	info.si_pid = task_pid_nr_ns(tsk, task_active_pid_ns(parent));
+	info.si_uid = from_kuid_munged(task_cred_xxx(parent, user_ns),
 				       task_uid(tsk));
 	rcu_read_unlock();
 
@@ -2227,7 +2228,7 @@ bool do_notify_parent(struct task_struct *tsk, int sig)
 		info.si_status = tsk->exit_code >> 8;
 	}
 
-	psig = tsk->parent->sighand;
+	psig = parent->sighand;
 	spin_lock_irqsave(&psig->siglock, flags);
 	if (!tsk->ptrace && sig == SIGCHLD &&
 	    (psig->action[SIGCHLD-1].sa.sa_handler == SIG_IGN ||
@@ -2256,10 +2257,11 @@ bool do_notify_parent(struct task_struct *tsk, int sig)
 	 * parent's namespaces.
 	 */
 	if (valid_signal(sig) && sig)
-		__send_signal_locked(sig, &info, tsk->parent, PIDTYPE_TGID, false);
-	__wake_up_parent(tsk, tsk->parent);
+		__send_signal_locked(sig, &info, parent, PIDTYPE_TGID, false);
+	__wake_up_parent(tsk, parent);
 	spin_unlock_irqrestore(&psig->siglock, flags);
 
+	put_task_struct(parent);
 	return autoreap;
 }
 
-- 
