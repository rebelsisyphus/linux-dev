From ab3a4b9f26744db6e4320b86f81ef876224beb9a Mon Sep 17 00:00:00 2001
From: Dong Chenchen <superdcc97@163.com>
Date: Fri, 17 Apr 2026 10:58:18 +0800
Subject: [PATCH 3/3] bpf: Add RFS flow recording BPF hook points independent
 of CONFIG_RPS

Add BPF hook points at sock_rps_record_flow, sock_rps_record_flow_hash
and sock_rps_delete_flow call sites. These hooks invoke BPF RFS record
programs that can update BPF maps to track flow-to-CPU mappings, replacing
the native rps_sock_flow_table with programmable map-based tracking.

The hooks are placed before the CONFIG_RPS guards so they work
regardless of whether CONFIG_RPS is enabled, satisfying the design
requirement that BPF-based RFS should be usable even with CONFIG_RPS
disabled.

When both BPF RFS and native RFS are active, both are called (BPF
first), allowing gradual migration from native to BPF-based steering.
---
 include/net/rps.h | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/include/net/rps.h b/include/net/rps.h
index f1794cd2e7fb..f216500160bf 100644
--- a/include/net/rps.h
+++ b/include/net/rps.h
@@ -6,6 +6,7 @@
 #include <linux/static_key.h>
 #include <net/sock.h>
 #include <net/hotdata.h>
+#include <net/rps_bpf.h>
 
 #ifdef CONFIG_RPS
 
@@ -149,6 +150,7 @@ static inline bool rfs_is_needed(void)
 
 static inline void sock_rps_record_flow_hash(__u32 hash)
 {
+	rfs_bpf_record_flow_hash(hash);
 #ifdef CONFIG_RPS
 	if (!rfs_is_needed())
 		return;
@@ -159,6 +161,7 @@ static inline void sock_rps_record_flow_hash(__u32 hash)
 
 static inline void sock_rps_record_flow(const struct sock *sk)
 {
+	rfs_bpf_record_flow(sk);
 #ifdef CONFIG_RPS
 	if (!rfs_is_needed())
 		return;
@@ -169,6 +172,7 @@ static inline void sock_rps_record_flow(const struct sock *sk)
 
 static inline void sock_rps_delete_flow(const struct sock *sk)
 {
+	rfs_bpf_delete_flow(sk);
 #ifdef CONFIG_RPS
 	if (!rfs_is_needed())
 		return;
